# SmartParking Valkyrie - Environment Configuration
# Đã cấu hình cho ESP32-CAM phần cứng thật

# ============================================================
# DATABASE CONFIGURATION
# ============================================================
DB_BACKEND=auto
SQLITE_DB_PATH=/home/minhviet/Documents/TestThuGui/smart_parking.db
DB_SERVER=localhost
DB_NAME=SmartParking_Valkyrie
DB_USER=sa
DB_PASSWORD=yourpassword
DB_TRUSTED_CONNECTION=no

# ============================================================
# API SERVER CONFIGURATION
# ============================================================
API_HOST=0.0.0.0
API_PORT=8000

# ============================================================
# CAMERA CONFIGURATION
# ============================================================
CAMERA_INDEX=0

# ============================================================
# FUZZY MATCHING
# ============================================================
FUZZY_THRESHOLD=75
MIN_BALANCE_REQUIRED=3000

# ============================================================
# ESP32-CAM HARDWARE (PHẦN CỨNG THẬT)
# ============================================================
ESP32_IP=10.36.47.61
MOCK_HARDWARE=no

# ============================================================
# ROBOFLOW (Optional - cho YOLO trên ESP32)
# ============================================================
ROBOFLOW_API_KEY=

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=INFO

# ============================================================
# SYSTEM SETTINGS
# ============================================================
# 1 = Enable (cấm xe ra/vào từ 23h - 6h)
# 0 = Unable (cho phép test hệ thống từ 23h - 6h)
TIME_LIMITED_23H_6H=0
