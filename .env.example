# SmartParking Valkyrie - Environment Configuration
# Copy file này thành .env và điều chỉnh theo máy của bạn

# ============================================================
# DATABASE CONFIGURATION
# ============================================================
DB_BACKEND=auto
SQLITE_DB_PATH=/home/minhviet/Documents/TestThuGui/smart_parking.db
DB_SERVER=localhost
DB_NAME=SmartParking_Valkyrie
DB_USER=sa
DB_PASSWORD=yourpassword
DB_TRUSTED_CONNECTION=no

# ============================================================
# API SERVER CONFIGURATION
# ============================================================
API_HOST=127.0.0.1
API_PORT=8000

# ============================================================
# CAMERA CONFIGURATION
# ============================================================
CAMERA_INDEX=0

# ============================================================
# FUZZY MATCHING
# ============================================================
FUZZY_THRESHOLD=75
MIN_BALANCE_REQUIRED=3000

# ============================================================
# ROBOFLOW (Optional - cho YOLO trên ESP32)
# ============================================================
ROBOFLOW_API_KEY=

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=INFO
